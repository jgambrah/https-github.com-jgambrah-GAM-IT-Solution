{
  "entities": {
    "demoRequest": {
      "title": "Demo Request",
      "description": "A request for a product demo from a potential customer.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "User's first name" },
        "lastName": { "type": "string", "description": "User's last name" },
        "email": { "type": "string", "format": "email", "description": "User's work email" },
        "product": { "type": "string", "enum": ["salesflow", "leadgenius", "insightdash"], "description": "The product they want a demo for" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the request was made" },
        "status": { "type": "string", "enum": ["pending", "contacted", "completed"], "description": "Current status of the request" }
      },
      "required": ["firstName", "lastName", "email", "product", "createdAt"]
    },
    "feedback": {
      "title": "Feedback",
      "description": "General feedback or feature requests from users.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's name" },
        "message": { "type": "string", "description": "The feedback message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the feedback was submitted" }
      },
      "required": ["name", "message", "createdAt"]
    },
    "testimonial": {
      "title": "Testimonial",
      "description": "A client testimonial to be displayed on the website.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Client's name" },
        "role": { "type": "string", "description": "Client's role/title" },
        "content": { "type": "string", "description": "The testimonial content" },
        "avatar": { "type": "string", "description": "URL to the client's avatar image" },
        "color": { "type": "string", "description": "Background color for the card (e.g., bg-indigo-500)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the testimonial was added" }
      },
      "required": ["name", "role", "content", "avatar", "createdAt"]
    },
    "news": {
      "title": "News & Updates",
      "description": "A news post or update from GAM IT Solutions.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the news post" },
        "content": { "type": "string", "description": "Main text content of the post" },
        "type": { "type": "string", "enum": ["text", "image", "video", "youtube", "instagram", "tiktok"], "description": "Type of media attached" },
        "mediaUrl": { "type": "string", "description": "URL to the media (image, video, or social link)" },
        "author": { "type": "string", "description": "Author of the post" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the post was created" }
      },
      "required": ["title", "content", "type", "createdAt"]
    },
    "team": {
      "title": "Team Member",
      "description": "A member of the GAM IT Solutions team.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Member's full name" },
        "role": { "type": "string", "description": "Member's role or title" },
        "bio": { "type": "string", "description": "Brief biography or personal statement" },
        "avatar": { "type": "string", "description": "URL to the member's profile picture" },
        "linkedin": { "type": "string", "description": "LinkedIn profile URL" },
        "github": { "type": "string", "description": "GitHub profile URL" },
        "kaggle": { "type": "string", "description": "Kaggle profile URL" },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "List of key skills" },
        "order": { "type": "integer", "description": "Display order" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the member was added" }
      },
      "required": ["name", "role", "bio", "avatar", "createdAt"]
    }
  },
  "firestore": {
    "/demoRequests/{requestId}": {
      "schema": "demoRequest",
      "description": "Collection of demo requests"
    },
    "/feedback/{feedbackId}": {
      "schema": "feedback",
      "description": "Collection of user feedback"
    },
    "/testimonials/{testimonialId}": {
      "schema": "testimonial",
      "description": "Collection of client testimonials"
    },
    "/news/{newsId}": {
      "schema": "news",
      "description": "Collection of news and updates"
    },
    "/team/{memberId}": {
      "schema": "team",
      "description": "Collection of team members"
    }
  }
}
