{
  "entities": {
    "flock": {
      "title": "Flock",
      "description": "A group of birds on the farm.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name or ID of the flock." },
        "breed": { "type": "string", "description": "The breed of the birds." },
        "source": { "type": "string", "description": "The source or supplier of the birds." },
        "ageWeeks": { "type": "integer", "description": "The age of the birds in weeks." },
        "initialCount": { "type": "integer", "description": "The initial number of birds in the flock." },
        "currentCount": { "type": "integer", "description": "The current number of birds in the flock." },
        "status": { "type": "string", "enum": ["active", "culled"], "description": "The status of the flock." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the flock was added." }
      },
      "required": ["name", "breed", "initialCount", "currentCount", "status", "createdAt"]
    },
    "eggProduction": {
      "title": "Egg Production",
      "description": "Daily egg production record for a flock.",
      "type": "object",
      "properties": {
        "flockId": { "type": "string", "description": "The ID of the flock." },
        "date": { "type": "string", "format": "date", "description": "The date of production." },
        "totalEggs": { "type": "integer", "description": "The total number of eggs collected." },
        "grading": {
          "type": "object",
          "properties": {
            "large": { "type": "integer" },
            "medium": { "type": "integer" },
            "small": { "type": "integer" },
            "cracked": { "type": "integer" }
          }
        },
        "notes": { "type": "string", "description": "Any additional notes." }
      },
      "required": ["flockId", "date", "totalEggs", "grading"]
    },
    "inventory": {
      "title": "Inventory Item",
      "description": "An item in the farm's inventory (feed, drugs, etc.).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Feed", "Drug", "Consumable"], "description": "The type of inventory item." },
        "name": { "type": "string", "description": "The name of the item." },
        "quantity": { "type": "number", "description": "The current quantity in stock." },
        "unit": { "type": "string", "description": "The unit of measurement (e.g., bags, liters, vials)." },
        "lowStockThreshold": { "type": "number", "description": "The threshold for low stock alerts." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the inventory was last updated." }
      },
      "required": ["type", "name", "quantity", "unit", "lowStockThreshold", "updatedAt"]
    },
    "transaction": {
      "title": "Financial Transaction",
      "description": "An income or expense transaction.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Income", "Expense"], "description": "The type of transaction." },
        "category": { "type": "string", "enum": ["Feed", "Labor", "Meds", "Sales", "Other"], "description": "The category of the transaction." },
        "amount": { "type": "number", "description": "The amount of the transaction." },
        "date": { "type": "string", "format": "date-time", "description": "The date of the transaction." },
        "description": { "type": "string", "description": "A description of the transaction." },
        "flockId": { "type": "string", "description": "The ID of the flock (optional)." }
      },
      "required": ["type", "category", "amount", "date", "description"]
    },
    "healthRecord": {
      "title": "Health Record",
      "description": "A health-related event for a flock.",
      "type": "object",
      "properties": {
        "flockId": { "type": "string", "description": "The ID of the flock." },
        "type": { "type": "string", "enum": ["Vaccination", "Medication", "VetVisit"], "description": "The type of health event." },
        "date": { "type": "string", "format": "date", "description": "The date of the event." },
        "description": { "type": "string", "description": "A description of the event." },
        "cost": { "type": "number", "description": "The cost of the event (optional)." }
      },
      "required": ["flockId", "type", "date", "description"]
    },
    "user": {
      "title": "User",
      "description": "A user of the system with a specific role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "The user's email." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "role": { "type": "string", "enum": ["CEO", "Manager", "Staff"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/flocks/{flockId}": {
      "schema": "flock",
      "description": "Collection of flocks."
    },
    "/eggProduction/{productionId}": {
      "schema": "eggProduction",
      "description": "Collection of egg production records."
    },
    "/inventory/{itemId}": {
      "schema": "inventory",
      "description": "Collection of inventory items."
    },
    "/transactions/{transactionId}": {
      "schema": "transaction",
      "description": "Collection of financial transactions."
    },
    "/healthRecords/{recordId}": {
      "schema": "healthRecord",
      "description": "Collection of health records."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of user profiles and roles."
    }
  }
}
